# =========================================================================
# VERCEL-SIDE (set in Vercel project env; .env.local for local dev)
# =========================================================================
# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=            # https://<ref>.supabase.co (public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=       # anon public key (RLS-bound, safe in browser)
SUPABASE_SERVICE_ROLE_KEY=           # SERVER ONLY — bypasses RLS; ingest + webhook only
SUPABASE_JWT_SECRET=                 # for verifying Supabase JWTs server-side (optional)
SUPABASE_DB_URL=                     # postgres connection string for migrations/CI

# --- Stripe ---
STRIPE_SECRET_KEY=                   # sk_live_… / sk_test_… (server only)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=  # pk_… (browser)
STRIPE_WEBHOOK_SECRET=               # whsec_… (verify raw-body signature)
STRIPE_PRICE_MONTHLY=                # price_… for $15/mo (unit_amount 1500)
STRIPE_PRICE_YEARLY=                 # price_… for $162/yr (unit_amount 16200)

# --- App ---
NEXT_PUBLIC_SITE_URL=                # https://sightlab.fysight.biz
SIGHTLAB_INGEST_SECRET=              # bearer token the Mac sends to /api/ingest (shared w/ Mac)
SIGHTLAB_INGEST_HMAC_KEY=            # HMAC-SHA256 key over the raw ingest body (shared w/ Mac)
SIGHTLAB_TELEGRAM_INVITE_LINK=       # invite-only channel link, shown to logged-in users (PLAN §15.2)

# --- Email digest (Resend, PLAN §15.3) ---
RESEND_API_KEY=                      # re_… (server only) — sends the daily email digest
SIGHTLAB_EMAIL_FROM=                 # pinned verified sender, e.g. SightLab <dispatch@fysight.biz>
SIGHTLAB_UNSUB_SECRET=               # server secret signing unsubscribe tokens (forge-proof)
SIGHTLAB_POSTAL_ADDRESS=             # physical mailing address rendered in the email footer (CAN-SPAM) — required in production; the digest refuses to send without it

# --- v2 seams (leave blank in v1) ---
TELEGRAM_BOT_TOKEN=                  # v2: server-side auto-post (v1 posts from the Mac)
SIGHTLAB_TELEGRAM_CHANNEL_ID=        # v2 server path; v1 uses the Mac-side copy of this
X_API_KEY=                           # v2 (Basic tier ≈ $100/mo)
X_API_SECRET=                        # v2
X_ACCESS_TOKEN=                      # v2
X_ACCESS_SECRET=                     # v2

# =========================================================================
# MAC-SIDE  ($CONFIG_DIR/.env, chmod 600 — NEVER the service-role key)
# Read by scripts/mac/run_sightlab_dispatch.sh, sightlab_watchdog.sh and
# assemble_dispatch.py. CONFIG_DIR itself defaults to ~/.config/sightlab and
# can only be overridden in the launchd plist environment (the scripts use it
# to FIND this file, so setting it inside the file has no effect).
# =========================================================================
# --- required by the dispatch runner ---
SIGHTLAB_DATA_DIR=                   # TCC-free working dir for work/ + logs/ — NEVER ~/Documents (launchd cannot read it)
SIGHTLAB_SKILLS_DIR=                 # base dir of the quant-harness skills (moomoo/ + cycle/ script trees)
SIGHTLAB_INGEST_URL=                 # https://<your-host>/api/ingest
# SIGHTLAB_INGEST_SECRET / SIGHTLAB_INGEST_HMAC_KEY MUST equal the Vercel values
TELEGRAM_API_KEY=                    # bot token — FAILURE ALERTS ONLY (DM), never dispatch content
TELEGRAM_CHAT_ID=                    # DM chat id the failure alerts go to
# --- optional tuning ---
PYTHON_BIN=                          # python3 interpreter to use (default: python3)
CLAUDE_BIN=                          # claude CLI for the ZH→EN pass (default: claude)
SIGHTLAB_TRANSLATE_MODEL=            # model override for the ZH→EN translation pass
SIGHTLAB_NO_TRANSLATE=               # =1 skips translation (ships en_pending=true)
# --- watchdog (sightlab_watchdog.sh) ---
SIGHTLAB_SITE_URL=                   # site base URL — fallback landed-check (NEXT_PUBLIC_SITE_URL also works);
                                     # the preferred landed-check reuses NEXT_PUBLIC_SUPABASE_URL + _ANON_KEY above
SIGHTLAB_WATCHDOG_GRACE_MIN=         # extra minutes to wait while a wake-catchup producer run is in flight (default 15)
# --- distribution + upstream data ---
SIGHTLAB_TELEGRAM_CHANNEL_ID=        # NEW invite-only channel (NOT the failure-alert DM)
FMP_API_KEY=                         # market-data API for the harness scripts
ANTHROPIC_API_KEY=                   # for the ZH→EN translation claude -p pass (optional with claude CLI)
SIGHTLAB_X_BEARER=                   # v2 only — leave unset in v1
